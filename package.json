{
  "name": "farm",
  "version": "0.1.0",
  "description": "A desktop-first browser idle farming game with tiny autonomous farmhands.",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5175 --strictPort",
    "playtest:llm": "node scripts/llm-playtest.mjs",
    "playtest:llm:visual-loop": "node scripts/llm-visual-loop.mjs",
    "playtest:llm:replay": "node scripts/llm-playtest-replay.mjs",
    "playtest:recursive": "node scripts/playtest-recursive.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests scripts --no-error-on-unmatched-pattern",
    "build": "tsc --noEmit && vite build"
  },
  "dependencies": {
    "civ-engine": "file:../civ-engine",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.0.0",
    "eslint": "^9.0.0",
    "globals": "^14.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.0.0",
    "vitest": "^3.2.0"
  }
}
